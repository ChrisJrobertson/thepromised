# Copy to `.env.test.local` (gitignored) for Playwright authenticated E2E tests.
# Requires a real Supabase user — see tests/e2e/authenticated.test.ts
#
# If PLAYWRIGHT_TEST_PASSWORD is unset, authenticated tests are skipped (marketing/auth E2E still run).

PLAYWRIGHT_TEST_EMAIL=smoke-test@theypromised.app
PLAYWRIGHT_TEST_PASSWORD=
PLAYWRIGHT_BASE_URL=http://localhost:3000
