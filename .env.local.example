# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Run: npx tsx src/lib/stripe/setup.ts to create and populate these
STRIPE_PRICE_ID_BASIC_MONTHLY=price_...
STRIPE_PRICE_ID_BASIC_ANNUAL=price_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...

# One-off complaint packs (Price IDs from Stripe Dashboard — names match Vercel)
STRIPE_PRICE_COMPLAINT_STARTER=price_...
STRIPE_PRICE_ESCALATION_PACK=price_...
STRIPE_PRICE_FULL_CASE_PACK=price_...

# ─── AI Providers ─────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
# The "From" address for outbound complaint letters (must be on a verified domain)
RESEND_FROM_EMAIL=complaints@theypromised.app
# The "From" address for admin/system emails (welcome, subscription confirm, etc.)
RESEND_ADMIN_FROM=hello@theypromised.app
# Set to "true" once your sending domain is verified in Resend
RESEND_DOMAIN_VERIFIED=true
# Webhook secret from Resend dashboard → Webhooks → your endpoint → Signing Secret
RESEND_WEBHOOK_SECRET=whsec_...

# ─── Rate Limiting (Upstash Redis) ────────────────────────────────────────────
# console.upstash.com → Create database → REST API tab
# Required in production — AI routes fall back to allow-all without these
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://theypromised.app
NEXT_PUBLIC_APP_NAME=TheyPromised

# ─── Security ─────────────────────────────────────────────────────────────────
# Random 32+ char string — used to authenticate the /api/reminders/cron endpoint
CRON_SECRET=
# Random 32+ char string — used to authenticate the /api/seed endpoint (one-time use)
SEED_SECRET=

# ─── B2B Alerts ───────────────────────────────────────────────────────────────
# Internal email address for B2B SLA breach alerts (falls back to support@ if unset)
B2B_ALERT_EMAIL=ops@theypromised.app

# ─── Analytics ────────────────────────────────────────────────────────────────
# PostHog — app.posthog.com (use EU region for GDPR). Client uses /ingest proxy; server uses host below.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
# Server-side PostHog only (client uses next.config rewrites to /ingest)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Error Monitoring ─────────────────────────────────────────────────────────
# sentry.io → Settings → Projects → your project → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
# sentry.io → Settings → Auth Tokens (needed for source map upload at build time)
SENTRY_AUTH_TOKEN=sntrys_...

# ─── Playwright E2E (optional — copy vars to .env.test.local for authenticated tests) ─
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_TEST_EMAIL=smoke-test@theypromised.app
# PLAYWRIGHT_TEST_PASSWORD=

# ─── Local Development Overrides ──────────────────────────────────────────────
# Uncomment when running locally:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# RESEND_DOMAIN_VERIFIED=false
