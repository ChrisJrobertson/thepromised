# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Run: npx tsx src/lib/stripe/setup.ts to create these
STRIPE_PRICE_ID_BASIC_MONTHLY=price_...
STRIPE_PRICE_ID_BASIC_ANNUAL=price_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...

# ─── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.theypromised.app
NEXT_PUBLIC_APP_NAME=TheyPromised

# ─── Security ─────────────────────────────────────────────────────────────────
# Random secret for cron job authentication
CRON_SECRET=

# Random secret for database seeding (one-time use)
SEED_SECRET=

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# PostHog (EU region recommended for GDPR compliance)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── Error Monitoring ─────────────────────────────────────────────────────────
# Sentry — create project at sentry.io and grab your DSN
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=

# ─── Development ──────────────────────────────────────────────────────────────
# Override for local dev
# NEXT_PUBLIC_APP_URL=http://localhost:3000
